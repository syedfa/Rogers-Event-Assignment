// 1. Copy this file to `Secrets.swift` in the same directory (App/).
// 2. Replace the placeholder below with your real Ticketmaster Discovery API key:
//    https://developer.ticketmaster.com/
// 3. `Secrets.swift` is listed in .gitignore and will never be committed —
//    this example file is the only one that lives in version control.
//
// A key embedded in a client binary is still technically extractable by a
// determined attacker; keeping it out of git history avoids the far more common
// leak vector (public repos, commit history, forks). See docs/ARCHITECTURE.md
// for the production-correct fix (a thin server-side proxy).

enum Secrets {
    static let ticketmasterAPIKey = "YOUR_TICKETMASTER_API_KEY"
}
